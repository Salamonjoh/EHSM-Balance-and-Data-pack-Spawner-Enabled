                </Item>
                <Item AmountMin="1" AmountMax="10">
                    <Frequency>1</Frequency>
                    <Id>
                        <TypeId>Ingot</TypeId>
                        <SubtypeId>Cobalt</SubtypeId>
                    </Id>
